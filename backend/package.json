{
  "name": "@sipgn/backend",
  "version": "1.0.0",
  "private": true,
  "description": "SIPGN-BGN backend (Express + Prisma)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "ingest:public": "node src/scripts/ingest/public-data.ingest.js",
    "ingest:bgn-scrape": "node src/scripts/ingest/bgn-scrape.ingest.js",
    "ingest:dummy-nutrition": "node src/scripts/ingest/dummy-nutrition.ingest.js",
    "ingest:realtime": "node src/scripts/ingest/realtime-generator.js",
    "ingest:all": "npm run ingest:public && npm run ingest:bgn-scrape && npm run ingest:dummy-nutrition && npm run ingest:realtime",
    "test": "jest --runInBand --detectOpenHandles --coverage",
    "test:watch": "jest --watch"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "@sipgn/shared": "1.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.10",
    "prisma": "^5.22.0",
    "puppeteer": "^23.10.4",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/__tests__/**",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
