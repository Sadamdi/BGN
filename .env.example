NODE_ENV=development

POSTGRES_DB=sipgn_bgn
POSTGRES_USER=sipgn
POSTGRES_PASSWORD=sipgn_password

JWT_SECRET=please-change-this-jwt-secret-min-32-chars-1234
JWT_REFRESH_SECRET=please-change-this-refresh-secret-min-32-chars
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@bgn.go.id
SMTP_PASS=

DATA_ENCRYPTION_KEY=please-change-this-32-byte-aes-key!!

# Token otorisasi endpoint /api/cron/*. Vercel Cron mengirim
# `Authorization: Bearer <CRON_SECRET>`. Set di Vercel dashboard
# (Settings -> Environment Variables, production) sebagai secret.
# Generate baru dengan: openssl rand -base64 48
CRON_SECRET=please-change-this-cron-secret-min-32-chars-1234
